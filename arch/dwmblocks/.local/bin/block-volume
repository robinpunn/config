#!/bin/sh

vol=$(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}' | head -n1 | tr -d '%')
mute=$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}')

if [ "$mute" = "yes" ]; then
	icon="ó°ťź"
elif [ "$vol" -ge 70 ]; then
	icon="ó°•ľ"
elif [ "$vol" -ge 30 ]; then
	icon="ó°–€"
elif [ "$vol" -ge 1 ]; then
	icon="ó°•ż"
else
	icon="ó°ťž"
fi

printf "%s %s%% î‚±" "$icon" "$vol"
