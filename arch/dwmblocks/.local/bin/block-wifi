#!/bin/sh

signal=$(nmcli -t -f IN-USE,SIGNAL dev wifi list | awk -F: '/^\*/{print $2}')
vpn=$(nmcli -t -f TYPE con show --active | grep -qE "vpn|wireguard|dummy" && echo yes)

if [ -z "$signal" ]; then
	icon="ůį§ģ"
elif [ "$signal" -ge 90 ]; then
	icon=$([ -n "$vpn" ] && echo "ůį§™" || echo "ůį§®")
elif [ "$signal" -ge 76 ]; then
	icon=$([ -n "$vpn" ] && echo "ůĪõć" || echo "ůį§•")
elif [ "$signal" -ge 56 ]; then
	icon=$([ -n "$vpn" ] && echo "ůĪõĆ" || echo "ůį§Ę")
elif [ "$signal" -ge 26 ]; then
	icon=$([ -n "$vpn" ] && echo "ůĪõč" || echo "ůį§ü")
else
	icon=$([ -n "$vpn" ] && echo "ůį§¨" || echo "ůį§Į")
fi

printf "%s ÓāĪ" "$icon"
